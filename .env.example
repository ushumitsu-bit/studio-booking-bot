# ─── Telegram ────────────────────────────────
BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_IDS=[123456789, 987654321]   # Ваши Telegram ID через запятую

# ─── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://pilates:password@localhost:5432/pilates_db

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Payme Business ──────────────────────────
# Получить в личном кабинете: https://merchant.payme.uz/
PAYME_MERCHANT_ID=your_merchant_id_here
PAYME_SECRET_KEY=your_secret_key_here         # TEST_KEY или PROD_KEY
PAYME_RETURN_URL=https://t.me/your_pilates_bot

# ─── Webhook (Payme → ваш сервер) ────────────
# Ваш публичный домен (нужен HTTPS!)
WEBHOOK_HOST=https://pilates.yourdomain.ru
WEBHOOK_PATH=/payme/webhook

# ─── Цены (сумы) ─────────────────────────────
PRICE_SINGLE=150000
PRICE_4_CLASSES=500000
PRICE_8_CLASSES=800000

# ─── Посещаемость ────────────────────────────
# Случайная строка для подписи QR-токенов (сгенерируй: python -c "import secrets; print(secrets.token_hex(32))")
ATTENDANCE_SECRET=change-me-generate-random-string
